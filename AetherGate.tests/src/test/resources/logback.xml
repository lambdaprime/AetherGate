<configuration>
	<contextListener
		class="ch.qos.logback.classic.jul.LevelChangePropagator">
		<!-- reset all previous level configurations of all JUL loggers to one 
			used by logback -->
		<resetJUL>true</resetJUL>
	</contextListener>

	<appender name="CONSOLE"
		class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{yyyy-MM-dd'T'HH:mm:ss} [%level] %msg%n</pattern>
		</encoder>
	</appender>

	<root level="DEBUG">
		<appender-ref ref="CONSOLE" />
	</root>

</configuration>